<style>
/* Custom Dropdown Styles - Enhanced */
.custom-dropdown {
    position: relative;
    width: 100%;
    max-width: 100%;
    font-family: 'Outfit', sans-serif;
    z-index: 10;
}
.custom-dropdown-selected {
    background: linear-gradient(90deg, #181818 80%, #232323 100%);
    color: var(--text-primary);
    border: 2px solid var(--primary);
    border-radius: 14px;
    padding: 16px 18px 16px 18px;
    font-size: 1.13rem;
    font-weight: 700;
    cursor: pointer;
    transition: border 0.2s, box-shadow 0.2s, background 0.2s;
    box-shadow: 0 4px 18px rgba(0,0,0,0.10);
    width: 100%;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    position: relative;
}
.dropdown-chevron {
    display: flex;
    align-items: center;
    margin-left: 8px;
    transition: transform 0.2s;
}
.custom-dropdown.open .dropdown-chevron {
    transform: rotate(180deg);
}
.custom-dropdown.open .custom-dropdown-selected,
.custom-dropdown-selected:focus {
    border-color: var(--secondary);
    box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.12);
    outline: none;
    background: linear-gradient(90deg, #232323 80%, #181818 100%);
}
.custom-dropdown-list {
    display: none;
    position: absolute;
    top: 110%;
    left: 0;
    width: 100%;
    background: #232323;
    border-radius: 0 0 14px 14px;
    box-shadow: 0 12px 32px rgba(0,0,0,0.28);
    margin: 0;
    padding: 0;
    list-style: none;
    z-index: 100;
    max-height: 240px;
    overflow-y: auto;
    border: 1.5px solid var(--primary);
    animation: dropdownFadeIn 0.18s;
}
@keyframes dropdownFadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
}
.custom-dropdown.open .custom-dropdown-list {
    display: block;
}
.custom-dropdown-list li {
    padding: 18px 22px;
    color: #fff;
    font-size: 1.13rem;
    cursor: pointer;
    border-bottom: 1px solid #333;
    transition: background 0.15s, color 0.15s, padding-left 0.18s;
    display: flex;
    align-items: center;
    gap: 12px;
}
.custom-dropdown-list li:last-child {
    border-bottom: none;
}
.custom-dropdown-list li:hover,
.custom-dropdown-list li.selected {
    background: linear-gradient(90deg, var(--primary) 60%, #ff6b3d 100%);
    color: #fff;
    padding-left: 32px;
}
.custom-dropdown-list li i {
    font-size: 1.2em;
    color: var(--primary);
    min-width: 22px;
    text-align: center;
}
@media (max-width: 600px) {
    .custom-dropdown-selected {
        font-size: 1.18rem;
        padding: 18px 14px;
        border-radius: 18px;
    }
    .custom-dropdown-list li {
        font-size: 1.15rem;
        padding: 20px 14px;
    }
}
</style>
<script>
// Custom Dropdown JS
document.addEventListener('DOMContentLoaded', function() {
    const dropdown = document.getElementById('assetTypeDropdown');
    const selected = document.getElementById('assetTypeSelected');
    const list = document.getElementById('assetTypeList');
    const hiddenInput = document.getElementById('assetTypeCustom');
    let open = false;

    function closeDropdown(e) {
        if (!dropdown.contains(e.target)) {
            dropdown.classList.remove('open');
            open = false;
        }
    }

    selected.addEventListener('click', function() {
        open = !open;
        dropdown.classList.toggle('open', open);
    });

    list.querySelectorAll('li').forEach(function(item) {
        item.addEventListener('click', function() {
            selected.textContent = item.textContent;
            hiddenInput.value = item.getAttribute('data-value');
            list.querySelectorAll('li').forEach(li => li.classList.remove('selected'));
            item.classList.add('selected');
            dropdown.classList.remove('open');
            open = false;
        });
    });

    document.addEventListener('click', closeDropdown);
});
</script>

