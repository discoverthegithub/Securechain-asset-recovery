                <button class="btn btn-confirm" id="confirmAction">Confirm</button>
            </div>
        </div>
    </div>

    <script src="/js/dashboard.js"></script>
    <script>
        // Particle canvas
        (function() {
            const canvas = document.getElementById('particleCanvas');
            const ctx = canvas.getContext('2d');
            let w, h, particles = [], mouse = { x: -1000, y: -1000 };
            function resize() { w = canvas.width = window.innerWidth; h = canvas.height = window.innerHeight; }
            window.addEventListener('resize', resize); resize();
            document.addEventListener('mousemove', e => { mouse.x = e.clientX; mouse.y = e.clientY; });
            const colors = ['rgba(255,74,28,0.5)','rgba(255,107,61,0.4)','rgba(255,150,100,0.3)'];
            for (let i = 0; i < 40; i++) {
                particles.push({ x: Math.random()*w, y: Math.random()*h, vx: (Math.random()-0.5)*0.4, vy: (Math.random()-0.5)*0.4, r: Math.random()*1.5+0.5, c: colors[Math.floor(Math.random()*colors.length)] });
            }
            function draw() {
                ctx.clearRect(0,0,w,h);
                particles.forEach((p,i) => {
                    p.x += p.vx; p.y += p.vy;
                    if (p.x < 0) p.x = w; if (p.x > w) p.x = 0;
                    if (p.y < 0) p.y = h; if (p.y > h) p.y = 0;
                    let dm = Math.hypot(p.x-mouse.x, p.y-mouse.y);
                    if (dm < 120) { p.x += (p.x-mouse.x)*0.015; p.y += (p.y-mouse.y)*0.015; }
                    ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
                    ctx.fillStyle = p.c; ctx.fill();
                    for (let j = i+1; j < particles.length; j++) {
                        let d = Math.hypot(p.x-particles[j].x, p.y-particles[j].y);
                        if (d < 100) { ctx.beginPath(); ctx.moveTo(p.x,p.y); ctx.lineTo(particles[j].x,particles[j].y); ctx.strokeStyle = 'rgba(255,74,28,'+(0.1*(1-d/100))+')'; ctx.stroke(); }
                    }
                });
                requestAnimationFrame(draw);
            }
            draw();
        })();

        // Block-reveal animation trigger on section switch
        function triggerBlockReveals(container) {
            const wrappers = (container || document).querySelectorAll('.block-reveal-wrapper');
            wrappers.forEach(w => {
                w.classList.remove('animate');
                void w.offsetWidth;
                w.classList.add('animate');
            });
        }
        // Trigger on initial load for visible section
        triggerBlockReveals(document.getElementById('dashboardSection'));
        // Hook into nav-item clicks to trigger on section switch
        document.querySelectorAll('.nav-item').forEach(item => {
            item.addEventListener('click', function() {
                const section = this.dataset.section;
                const sectionMap = { dashboard: 'dashboardSection', assets: 'assetsSection', history: 'historySection', settings: 'settingsSection', help: 'helpSection' };
                setTimeout(() => {
                    const el = document.getElementById(sectionMap[section]);
                    if (el) triggerBlockReveals(el);
                }, 50);
            });
        });
    </script>
    <script src="/js/page-transition.js"></script>
</body>