<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register | SecureChain</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #FF4A1C;
            --primary-dark: #D93B12;
            --primary-glow: rgba(255, 74, 28, 0.4);
            --secondary: #FFFFFF;
            --accent: #FF4A1C;
            --bg-dark: #0a0a0a;
            --bg-card: #111111;
            --text-primary: #FFFFFF;
            --text-secondary: #AAAAAA;
            --text-muted: #888888;
            --border: rgba(255, 255, 255, 0.08);
            --gradient-primary: linear-gradient(135deg, #FF4A1C, #FF6B3D);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { height: 100%; }
        body { min-height: 100%; font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif; }

        body {
            min-height: 100vh; background: var(--bg-dark);
            display: flex; align-items: center; justify-content: center;
            padding: 24px; position: relative; overflow-x: hidden;
        }

        body::before {
            content: ''; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(ellipse at 80% 20%, rgba(255, 74, 28, 0.08) 0%, transparent 50%),
                        radial-gradient(ellipse at 20% 80%, rgba(255, 74, 28, 0.05) 0%, transparent 50%);
            z-index: 0;
        }

        #gridBg {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0;
            background-size: 50px 50px;
            background-image: linear-gradient(to right, rgba(255, 74, 28, 0.03) 1px, transparent 1px),
                              linear-gradient(to bottom, rgba(255, 74, 28, 0.03) 1px, transparent 1px);
            transform: perspective(500px) rotateX(60deg) translateY(-100px) translateZ(-200px);
            animation: gridMove 20s linear infinite;
        }
        @keyframes gridMove { 0% { background-position: 0 0; } 100% { background-position: 50px 50px; } }

        .orb { position: fixed; border-radius: 50%; filter: blur(80px); z-index: 0; animation: orbDrift 12s ease-in-out infinite; }
        .orb-1 { width: 350px; height: 350px; background: rgba(255, 74, 28, 0.1); top: -80px; left: -80px; }
        .orb-2 { width: 280px; height: 280px; background: rgba(255, 107, 61, 0.06); bottom: -60px; right: -60px; animation-delay: -6s; }
        @keyframes orbDrift { 0%, 100% { transform: translate(0,0) scale(1); } 33% { transform: translate(30px,-20px) scale(1.05); } 66% { transform: translate(-20px,15px) scale(0.95); } }

        canvas#particleCanvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }

        /* Wide two-panel layout */
        .register-container {
            width: 100%; max-width: 900px; position: relative; z-index: 1;
            display: flex; min-height: 560px;
            animation: cardSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0; transform: translateY(30px);
        }
        @keyframes cardSlideUp { to { opacity: 1; transform: translateY(0); } }

        /* Left branding panel */
        .brand-panel {
            flex: 0 0 40%; background: linear-gradient(135deg, #FF4A1C 0%, #D93B12 100%);
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            padding: 48px 36px; position: relative; overflow: hidden;
        }
        .brand-panel::before {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
            opacity: 0.5;
        }
        .brand-panel .brand-icon {
            width: 80px; height: 80px; background: rgba(255,255,255,0.15);
            display: flex; align-items: center; justify-content: center;
            font-size: 2.2rem; color: #fff; margin-bottom: 28px; border: 2px solid rgba(255,255,255,0.3);
        }
        .brand-panel h1 {
            font-family: 'Outfit', sans-serif; font-size: 2rem; font-weight: 900;
            color: #fff; text-align: center; margin-bottom: 12px; letter-spacing: -0.5px;
        }
        .brand-panel p {
            color: rgba(255,255,255,0.8); font-size: 0.9rem; text-align: center;
            max-width: 240px; line-height: 1.6;
        }
        .brand-panel .brand-features {
            margin-top: 28px; display: flex; flex-direction: column; gap: 10px;
        }
        .brand-panel .brand-features .feat {
            display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.9); font-size: 0.8rem; font-weight: 500;
        }
        .brand-panel .brand-features .feat i {
            width: 24px; height: 24px; background: rgba(255,255,255,0.2); display: flex;
            align-items: center; justify-content: center; font-size: 0.7rem;
        }

        /* Right form panel */
        .form-panel {
            flex: 1; background: rgba(17, 17, 17, 0.95); backdrop-filter: blur(24px);
            border: 1px solid var(--border); border-left: none;
            padding: 36px 40px; display: flex; flex-direction: column; justify-content: center;
            position: relative; overflow: hidden;
        }

        .back-link {
            display: inline-flex; align-items: center; gap: 8px;
            color: var(--text-muted); text-decoration: none; font-size: 0.85rem;
            margin-bottom: 16px; transition: all 0.3s; font-weight: 600;
        }
        .back-link:hover { color: var(--primary); transform: translateX(-4px); }

        .card-title {
            font-family: 'Outfit', sans-serif; font-size: 1.6rem; font-weight: 800;
            margin-bottom: 6px; color: var(--primary); letter-spacing: -0.5px;
        }
        .block-reveal-wrapper { position: relative; display: inline-block; padding: 0 4px; }
        .block-reveal-wrapper::after {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background-color: var(--primary); transform-origin: left; transform: scaleX(0); z-index: 2;
            animation: blockSweep 1.2s cubic-bezier(0.8, -0.1, 0.2, 1) 0.3s forwards;
        }
        .block-reveal-text { opacity: 0; position: relative; z-index: 1; animation: textAppear 0.1s 0.9s forwards; }
        @keyframes blockSweep { 0% { transform-origin: left; transform: scaleX(0); } 40% { transform-origin: left; transform: scaleX(1); } 60% { transform-origin: right; transform: scaleX(1); } 100% { transform-origin: right; transform: scaleX(0); } }
        @keyframes textAppear { 100% { opacity: 1; } }

        .card-subtitle { color: var(--text-muted); font-size: 0.85rem; margin-bottom: 24px; }

        .form-group { margin-bottom: 18px; }
        .form-label { display: block; font-weight: 600; color: var(--text-secondary); margin-bottom: 6px; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px; }
        .input-wrapper { position: relative; display: flex; align-items: center; }
        .input-icon { position: absolute; left: 14px; color: var(--text-muted); font-size: 0.95rem; transition: color 0.3s; z-index: 2; }

        .form-control {
            width: 100%; padding: 12px 14px 12px 44px;
            background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border); border-radius: 0;
            color: var(--text-primary); font-size: 0.9rem; font-family: 'Plus Jakarta Sans', sans-serif;
            transition: all 0.3s ease; outline: none;
        }
        .form-control::placeholder { color: var(--text-muted); }
        .form-control:focus { border-color: var(--primary); background: rgba(255, 74, 28, 0.04); box-shadow: 0 0 0 4px rgba(255, 74, 28, 0.1); }
        .input-wrapper:focus-within .input-icon { color: var(--primary); }

        .btn-register {
            width: 100%; padding: 12px; background: var(--primary); color: #111;
            border: none; border-radius: 0; font-size: 0.85rem; font-weight: 800;
            font-family: 'Plus Jakarta Sans', sans-serif; cursor: pointer;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            box-shadow: 0 4px 20px var(--primary-glow);
            display: flex; align-items: center; justify-content: center; gap: 8px;
            margin-top: 4px; position: relative; overflow: hidden;
            letter-spacing: 1px; text-transform: uppercase;
        }
        .btn-register::before { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent); transition: left 0.5s ease; }
        .btn-register:hover { transform: translateY(-2px); box-shadow: 0 8px 32px var(--primary-glow); }
        .btn-register:hover::before { left: 100%; }
        .btn-register:active { transform: translateY(0); }

        .strength-bar { height: 3px; border-radius: 0; margin-top: 6px; background: var(--border); overflow: hidden; }
        .strength-bar-fill { height: 100%; width: 0%; transition: all 0.3s; }

        .divider { display: flex; align-items: center; gap: 16px; margin: 18px 0; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

        .footer-links { text-align: center; }
        .footer-links a { display: inline-flex; align-items: center; gap: 8px; text-decoration: none; color: var(--primary); font-weight: 600; font-size: 0.85rem; transition: all 0.3s; }
        .footer-links a:hover { color: #FF6B3D; }
        .copyright { text-align: center; margin-top: 18px; color: var(--text-muted); font-size: 0.75rem; }

        /* Mobile: stack vertically */
        @media (max-width: 768px) {
            .register-container { flex-direction: column; max-width: 460px; min-height: auto; }
            .brand-panel { padding: 32px 24px; }
            .brand-panel h1 { font-size: 1.5rem; }
            .brand-panel .brand-features { display: none; }
            .form-panel { border-left: 1px solid var(--border); border-top: none; padding: 28px 24px; }
        }
    </style>
    <link rel="stylesheet" href="/css/page-transition.css">
</head>

<body>
    <div id="gridBg"></div>
    <canvas id="particleCanvas"></canvas>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <div class="register-container">
        <!-- Left branding panel -->
        <div class="brand-panel">
            <div class="brand-icon"><i class="fas fa-user-plus"></i></div>
            <h1>Join SecureChain</h1>
            <p>Create your account and start protecting your digital assets today.</p>
            <div class="brand-features">
                <div class="feat"><i class="fas fa-shield-alt"></i> Military-Grade Encryption</div>
                <div class="feat"><i class="fas fa-cube"></i> Blockchain Verified</div>
                <div class="feat"><i class="fas fa-bolt"></i> Instant Setup</div>
                <div class="feat"><i class="fas fa-lock"></i> Zero-Knowledge Proof</div>
            </div>
        </div>

        <!-- Right form panel -->
        <div class="form-panel">
            <a href="/" class="back-link"><i class="fas fa-arrow-left"></i> Back to Home</a>

            <h2 class="card-title">
                <span class="block-reveal-wrapper"><span class="block-reveal-text">Create Account</span></span>
            </h2>
            <p class="card-subtitle">Fill in your details to get started</p>

            <form action="/user/register" method="POST">
                <div class="form-group">
                    <label for="username" class="form-label">Username</label>
                    <div class="input-wrapper">
                        <i class="fas fa-user input-icon"></i>
                        <input type="text" class="form-control" id="username" name="username"
                            placeholder="Choose a username" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="email" class="form-label">Email Address</label>
                    <div class="input-wrapper">
                        <i class="fas fa-envelope input-icon"></i>
                        <input type="email" class="form-control" id="email" name="email" placeholder="your@email.com"
                            required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="password" class="form-label">Password</label>
                    <div class="input-wrapper">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" class="form-control" id="password" name="password"
                            placeholder="Create a strong password" required>
                    </div>
                    <div class="strength-bar">
                        <div class="strength-bar-fill" id="strengthFill"></div>
                    </div>
                </div>

                <button type="submit" class="btn-register">
                    <i class="fas fa-rocket"></i> Create Account
                </button>
            </form>

            <div class="divider">or</div>

            <div class="footer-links">
                <a href="/user/login">
                    <i class="fas fa-arrow-left"></i> Already have an account? Sign in
                </a>
            </div>

            <div class="copyright">
                &copy; 2025 SecureChain. All rights reserved.
            </div>
        </div>
    </div>

    <script>
        // Password strength indicator
        const passwordInput = document.getElementById('password');
        const strengthFill = document.getElementById('strengthFill');

        passwordInput.addEventListener('input', function () {
            const val = this.value;
            let strength = 0;
            if (val.length >= 6) strength += 25;
            if (val.length >= 10) strength += 25;
            if (/[A-Z]/.test(val) && /[a-z]/.test(val)) strength += 25;
            if (/[0-9]/.test(val) || /[^A-Za-z0-9]/.test(val)) strength += 25;

            strengthFill.style.width = strength + '%';
            if (strength <= 25) strengthFill.style.background = '#FF6B6B';
            else if (strength <= 50) strengthFill.style.background = '#FFB800';
            else if (strength <= 75) strengthFill.style.background = '#FF6B3D';
            else strengthFill.style.background = '#FF4A1C';
        });

        // Particle canvas
        (function() {
            const canvas = document.getElementById('particleCanvas');
            const ctx = canvas.getContext('2d');
            let w, h, particles = [], mouse = { x: -1000, y: -1000 };
            function resize() { w = canvas.width = window.innerWidth; h = canvas.height = window.innerHeight; }
            window.addEventListener('resize', resize); resize();
            document.addEventListener('mousemove', e => { mouse.x = e.clientX; mouse.y = e.clientY; });
            const colors = ['rgba(255,74,28,0.6)','rgba(255,107,61,0.5)','rgba(255,150,100,0.4)'];
            for (let i = 0; i < 50; i++) {
                particles.push({ x: Math.random()*w, y: Math.random()*h, vx: (Math.random()-0.5)*0.5, vy: (Math.random()-0.5)*0.5, r: Math.random()*2+1, c: colors[Math.floor(Math.random()*colors.length)] });
            }
            function draw() {
                ctx.clearRect(0,0,w,h);
                particles.forEach((p,i) => {
                    p.x += p.vx; p.y += p.vy;
                    if (p.x < 0) p.x = w; if (p.x > w) p.x = 0;
                    if (p.y < 0) p.y = h; if (p.y > h) p.y = 0;
                    let dm = Math.hypot(p.x-mouse.x, p.y-mouse.y);
                    if (dm < 120) { p.x += (p.x-mouse.x)*0.02; p.y += (p.y-mouse.y)*0.02; }
                    ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
                    ctx.fillStyle = p.c; ctx.fill();
                    for (let j = i+1; j < particles.length; j++) {
                        let d = Math.hypot(p.x-particles[j].x, p.y-particles[j].y);
                        if (d < 100) { ctx.beginPath(); ctx.moveTo(p.x,p.y); ctx.lineTo(particles[j].x,particles[j].y); ctx.strokeStyle = 'rgba(255,74,28,'+(0.15*(1-d/100))+')'; ctx.stroke(); }
                    }
                });
                requestAnimationFrame(draw);
            }
            draw();
        })();
    </script>
    <script src="/js/page-transition.js"></script>
</body>

</html>